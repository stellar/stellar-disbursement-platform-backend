# Database Configuration
DATABASE_URL="postgres://postgres:postgres@localhost:5432/anchor_platform?sslmode=disable"
DATA_SERVER="localhost:5432"
DATA_DATABASE="anchor_platform"
DATA_USERNAME="postgres"
DATA_PASSWORD="postgres"

# Anchor Platform Configuration
HOST_URL="http://localhost:8080"
SEP_SERVER_PORT=8080
PLATFORM_SERVER_PORT=8085
CALLBACK_API_BASE_URL="http://localhost:8000"
CALLBACK_API_AUTH_TYPE="none"
PLATFORM_SERVER_AUTH_TYPE="JWT"
APP_LOGGING_LEVEL="INFO"
DATA_TYPE="postgres"
DATA_FLYWAY_ENABLED="true"
DATA_DDL_AUTO="update"
METRICS_ENABLED="true"
METRICS_EXTRAS_ENABLED="false"

# SEP Configuration
SEP10_ENABLED="true"
SEP10_HOME_DOMAINS="localhost:8000, *.stellar.local:8000"
SEP10_HOME_DOMAIN=""
SEP10_WEB_AUTH_DOMAIN="localhost:8080"
SEP24_ENABLED="true"
SEP24_INTERACTIVE_URL_BASE_URL="http://localhost:8000/wallet-registration/start"
SEP24_INTERACTIVE_URL_JWT_EXPIRATION=1800
SEP24_MORE_INFO_URL_BASE_URL="http://localhost:8000/wallet-registration/start"
SEP1_ENABLED="true"
SEP1_TOML_TYPE="url"
SEP1_TOML_VALUE="http://localhost:8000/.well-known/stellar.toml"

# SDP Configuration
ANCHOR_PLATFORM_BASE_URL="http://localhost:8080"
ANCHOR_PLATFORM_PLATFORM_URL="http://localhost:8085"
ANCHOR_PLATFORM_BASE_PLATFORM_URL="http://localhost:8085"
ANCHOR_PLATFORM_BASE_SEP_URL="http://localhost:8080"
ANCHOR_PLATFORM_AUTH_SECRET="mySdpToAnchorPlatformSecret"
ANCHOR_PLATFORM_AUTH_TYPE="JWT"
ANCHOR_PLATFORM_OUTGOING_JWT_SECRET="mySdpToAnchorPlatformSecret"

# SDP Basic Configuration
BASE_URL="http://localhost:8000"
ENVIRONMENT="localhost"
LOG_LEVEL="INFO"
PORT="8000"
METRICS_PORT="8002"
METRICS_TYPE="PROMETHEUS"
EMAIL_SENDER_TYPE="DRY_RUN"
SMS_SENDER_TYPE="DRY_RUN"
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
RECAPTCHA_SITE_KEY="6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI"
DISABLE_MFA="true"
DISABLE_RECAPTCHA="true"
CORS_ALLOWED_ORIGINS="*"

# SDP Multi-tenant Configuration
ADMIN_PORT="8003"
INSTANCE_NAME="SDP Local Development"
TENANT_XLM_BOOTSTRAP_AMOUNT="5"
SINGLE_TENANT_MODE="false"

# SDP Scheduler Configuration
SCHEDULER_RECEIVER_INVITATION_JOB_SECONDS="10"
SCHEDULER_PAYMENT_JOB_SECONDS="10"
EVENT_BROKER_TYPE="SCHEDULER"

